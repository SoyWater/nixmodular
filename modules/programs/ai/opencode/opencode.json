{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "provider": {
    "modal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal",
      "options": {
        "baseURL": "https://api.us-west-2.modal.direct/v1",
        "apiKey": "modalresearch_psY7Z-rkSjiM-MoHxJnmGnccV4jqUU-nALD6c9wnXE0"
      },
      "models": {
        "zai-org/GLM-5-FP8": {
          "name": "GLM-5"
        }
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "mkdir": "allow",
      "npm": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    },
    "external_directory": "ask",
  },
