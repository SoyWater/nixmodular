{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "mkdir": "allow",
      "npm": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    },
    "external_directory": "ask",
  },
}